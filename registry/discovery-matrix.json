{
  "version": "1.0",
  "description": "Intent keywords → npx skills find queries → ultra specialist + companions",
  "protocol": [
    "1. Match user intent to row below",
    "2. Run: npx skills find \"<query>\"",
    "3. Rank results: companions.json preferred_owners + min_installs_trusted",
    "4. Route to ultra_skill unless external skill is strictly better AND user wants install",
    "5. Never recommend duplicate — if synthesized (tier S), use ultra only"
  ],
  "matrix": [
    {
      "intents": ["find skill", "find a skill", "skills.sh", "which skill", "is there a skill"],
      "queries": ["find skills", "skill hub"],
      "ultra_skill": "ultra-skill-discovery",
      "fallback_chain": ["apple-hub"]
    },
    {
      "intents": ["design", "ui", "ux", "frontend", "polish", "apple design"],
      "queries": ["design", "frontend design", "web design guidelines"],
      "ultra_skill": "apple-design-head",
